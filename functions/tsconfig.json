{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "../",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "strictNullChecks": false,
    "paths": {
      "@models/*": ["../models/*"]
    }
  },
  "compileOnSave": true,
  "include": ["src"]
}
